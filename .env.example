# Copy to .env for local dev. On Render, set these in the dashboard's
# Environment tab instead — never commit a real .env.

# Long random string used to sign session tokens. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_this_with_a_long_random_string

# Set to "production" on Render so cookies require HTTPS.
NODE_ENV=development

PORT=3000

# Should already be set on Render to your persistent Disk's mount path
# (e.g. /var/data) so vouchers/tiers/users survive deploys. Check
# Render → this service → Environment, and → Disk, to confirm they match.
DATA_DIR=.
